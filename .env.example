# Supabase project URL — copy from Supabase Dashboard > Project Settings > Data API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase publishable (anon) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_rvFfflMOZFBiy8vTVRiaVA_aB_qPMjl

# Supabase secret key — SERVER ONLY, never expose. Used for admin/seed scripts.
# Copy from Supabase Dashboard > Project Settings > API keys (secret)
SUPABASE_SECRET_KEY=sb_secret_xxx
